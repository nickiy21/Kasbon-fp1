// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

enum Role {
  EMPLOYEE
  ADMIN
  HC
  FINANCE
  DOORSMER
  MARKETING
  MEKANIK
}

enum Division {
  DOORSMER
  MARKETING
  MEKANIK
  CUCI
  LAP
  KASIR
  QC_CUCI
  QC_LAP
  MESIN
  SPBL
  AC
  DETAILING
  FINANCE
  ACCOUNTING
  LOGISTIC
  SECURITY
  OB
  MAINTENANCE
  HC
  EXPEDISI
  OTHERS
}

enum KasbonStatus {
  PENDING
  LEADER_VERIFIED
  FINANCE_VERIFIED
  APPROVED
  REJECTED
  DISBURSED
  PAID
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  password      String
  nik           String?   @unique
  role          Role      @default(EMPLOYEE)
  division      Division?
  createdAt     DateTime  @default(now())
  
  employeeProfile EmployeeProfile?
  
  // Relations for Kasbon
  requests            KasbonRequest[] @relation("EmployeeRequests")
  leaderVerifications KasbonRequest[] @relation("LeaderVerifications")
  ownerApprovals      KasbonRequest[] @relation("OwnerApprovals")
}

model EmployeeProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  
  basicSalary   Float
  joinDate      DateTime
  spStatus      Boolean   @default(false) // true if has active SP
  isBlacklisted Boolean   @default(false)
}

model KasbonRequest {
  id                  String       @id @default(cuid())
  amount              Float
  purpose             String
  isMedicalEmergency  Boolean      @default(false)
  repaymentMonths     Int          @default(1)
  status              KasbonStatus @default(PENDING)
  submissionDate      DateTime     @default(now())
  
  // New fields for the updated form
  employeeName        String?
  nik                 String?
  division            Division?    @default(DOORSMER)
  joinDate            DateTime?
  spStatus            Boolean?     @default(false)
  isPreviousPaid      Boolean?     @default(true)
  basicSalary         Float?
  
  // Target role for approval
  accRole             Role?        @default(HC)
  
  // Employee who requested
  employeeId          String
  employee            User         @relation("EmployeeRequests", fields: [employeeId], references: [id])
  
  // Leader (SPV) who verified
  leaderId            String?
  leader              User?        @relation("LeaderVerifications", fields: [leaderId], references: [id])
  
  // Owner who approved
  ownerId             String?
  owner               User?        @relation("OwnerApprovals", fields: [ownerId], references: [id])
  
  // Rejection reason
  rejectionReason     String?
  spDescription       String?
  notes               String?
  
  // Response notes for each stage
  spvNotes            String?
  financeNotes        String?
  adminNotes          String?
}

